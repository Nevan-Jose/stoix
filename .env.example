# Copy this to `.env` and fill in your keys.

# Required for all AI features (Red Pill protocol + Blue Pill quests/skills)
GEMINI_API_KEY=your-key-here

# Optional: Google Places + Distance Matrix keys unlock real nearby venues for Blue Pill.
# Without these, Blue Pill falls back to Gemini-generated suggestions.
# GOOGLE_PLACES_KEY=your-key-here
# GOOGLE_MAPS_KEY=your-key-here

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
PORT=8787
