# Copy this to `.env` and fill in your keys.

# --- Red Pill /protocol (generate-tasks) — OpenRouter (cloud) or local Ollama ---
# https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=qwen/qwen2.5-72b-instruct
OPENROUTER_MODEL_FALLBACKS=meta-llama/llama-3.3-70b-instruct,mistralai/mistral-7b-instruct
OPENROUTER_VISION_MODEL=qwen/qwen2-vl-7b-instruct

# Optional OpenRouter overrides
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=STOIX Red Pill
# OPENROUTER_TIMEOUT_RESEARCH=180
# OPENROUTER_TIMEOUT_PLAN=600
# OPENROUTER_TIMEOUT_VISION=180
# OPENROUTER_MAX_TOKENS=16384

# If OPENROUTER_API_KEY is unset, Red Pill falls back to local Ollama:
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_VISION_MODEL=llava:latest

# --- Blue Pill (quests / skill-path) — Google Gemini ---
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Optional: Google Places + Distance Matrix for real nearby venues (Blue Pill).
# Without these, Blue Pill falls back to Gemini-generated suggestions.
# GOOGLE_PLACES_KEY=your-key-here
# GOOGLE_MAPS_KEY=your-key-here

PORT=8787
